rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 좌석배치도 프로젝트: 로그인한 팀원이면 누구나 읽고 쓸 수 있는 공유 문서
    // (기존 앱스크립트 버전이 스프레드시트 하나를 팀 전체가 공유하던 방식과 동일)
    match /seatLayoutProjects/{projectId} {
      allow read, write: if request.auth != null;
    }

    // 매장 전체보기(갤러리)에 등록된 최신 발주 이미지 메타데이터
    match /seatLayoutGallery/{entryId} {
      allow read, write: if request.auth != null;
    }
  }
}
